# ============================================================
# KOBİ AI Platform — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# .env asla git'e eklenmez!
# ============================================================

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ─── SQLite Veritabanı ────────────────────────────────────────
# Varsayılan: db/kobi_demo.db (proje kökü)
# SQLITE_DB_PATH=db/kobi_demo.db

# ─── ChromaDB ─────────────────────────────────────────────────
CHROMA_COLLECTION=kobi_ai_schema

# ─── JWT Güvenlik ─────────────────────────────────────────────
JWT_SECRET=kobi-ai-super-secret-2026-degistir
JWT_EXPIRE_H=24

# ─── Pipeline / Chat PIN (admin erişim) ───────────────────────
CHAT_PIN=demo2026
PIPELINE_PIN=pipeline123

# ─── Telegram Bot ────────────────────────────────────────────
# BotFather'dan alın: /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ─── RAG Ayarları ────────────────────────────────────────────
TOP_K_RESULTS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Opsiyonel: Google Cloud TTS/STT ─────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}
